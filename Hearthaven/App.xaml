<Application x:Class="Hearthaven.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Themes/Theme.Blue.xaml" />
                <ResourceDictionary Source="Styles/Converters.xaml" />
                <ResourceDictionary Source="Styles/SettingsStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ═══════════════ 阴影效果 ═══════════════ -->
            <DropShadowEffect x:Key="ShadowCard"
                              BlurRadius="12"
                              Opacity="0.06"
                              ShadowDepth="2"
                              Direction="270"
                              Color="#000000" />
            <!-- 用户消息气泡阴影（已移除：DropShadowEffect 会导致文字 ClearType 渲染被禁用，文字发虚） -->


            <!-- ═══════════════ 统一圆角 ═══════════════ -->
            <CornerRadius x:Key="RadiusCard">12</CornerRadius>
            <CornerRadius x:Key="RadiusBubble">10</CornerRadius>
            <CornerRadius x:Key="RadiusButton">8</CornerRadius>
            <CornerRadius x:Key="RadiusInput">8</CornerRadius>

            <!-- ═══════════════ 全局字体 ═══════════════ -->
            <FontFamily x:Key="FontFamily">Microsoft YaHei, Segoe UI Variable, Segoe UI</FontFamily>

            <!-- ═══════════════ 托盘图标（炉心标志） ═══════════════ -->
            <BitmapImage x:Key="TrayIcon"
                          UriSource="/Assets/Images/Logo.ico"
                          DecodePixelWidth="32"
                          DecodePixelHeight="32" />

            <!-- ═══════════════ 全局控件样式 ═══════════════ -->

            <!-- Button 全局样式 -->
            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource FontFamily}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource BrushText}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusButton}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrushHover}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrushHover}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox 全局样式 -->
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource FontFamily}" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource BrushInputBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BrushInputBorder}" />
                <Setter Property="Foreground" Value="{DynamicResource BrushText}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource RadiusInput}">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                </Trigger>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrushInputBg}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ScrollViewer 全局样式（去掉 WPF 默认的丑陋箭头按钮） -->
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="6" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
