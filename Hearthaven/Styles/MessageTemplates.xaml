<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Hearthaven.Controls"
                    xmlns:vm="clr-namespace:Hearthaven.Models">

    <!-- ReasoningBlock 模板 -->
    <DataTemplate DataType="{x:Type vm:ReasoningBlock}">
        <Border Padding="0"
                Margin="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0"
                        Padding="0,4"
                        Background="Transparent"
                        Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ToggleExpandCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 状态文字：思考中 ↔ 已思考 -->
                        <TextBlock Grid.Column="0"
                                   FontSize="11"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⏳ 思考中..."/>
                                    <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThinking}" Value="False">
                                            <Setter Property="Text" Value="💭 已思考"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 右侧图标 -->
                        <Grid Grid.Column="1"
                              Width="16" Height="16"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0">
                            <!-- 转动的圈（思考中） -->
                            <Ellipse x:Name="SpinnerArc"
                                     Width="12" Height="12"
                                     Stroke="{DynamicResource BrushAccent}"
                                     StrokeThickness="2"
                                     StrokeDashArray="3.5,10"
                                     RenderTransformOrigin="0.5,0.5"
                                     Visibility="{Binding IsThinking, Converter={StaticResource BoolToVisibilityConverter}}"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <RotateTransform Angle="0"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsThinking}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="RenderTransform.Angle"
                                                                From="0" To="360"
                                                                Duration="0:0:1"
                                                                RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="RenderTransform.Angle"
                                                                To="0"
                                                                Duration="0:0:0"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 思考内容 -->
                <Border Grid.Row="1"
                        Padding="12,0,0,4"
                        Background="Transparent"
                        BorderThickness="3,0,0,0"
                        BorderBrush="{DynamicResource BrushAccent}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Content}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="11"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- RoundBlock 内容区：流式模板（轻量 TextBlock） -->
    <DataTemplate x:Key="RoundBlockStreamingContent">
        <StackPanel>
            <TextBlock Text="{Binding Content}"
                       Foreground="{DynamicResource BrushText}"
                       FontSize="14"
                       TextWrapping="Wrap" />
            <TextBlock Text="▌"
                       Foreground="{DynamicResource BrushAccent}"
                       FontSize="14"
                       FontWeight="Bold"
                       Visibility="{Binding HasContent, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>
    </DataTemplate>

    <!-- RoundBlock 内容区：渲染模板（MarkdownViewer + FlowDocument） -->
    <DataTemplate x:Key="RoundBlockRenderedContent">
        <controls:MarkdownViewer Markdown="{Binding Content}" />
    </DataTemplate>

    <!-- ToolCallBlock 模板 -->
    <DataTemplate DataType="{x:Type vm:ToolCallBlock}">
        <Border Padding="0"
                Margin="0,0,0,2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题栏（点击切换展开/折叠） -->
                <Border Grid.Row="0"
                        Padding="0,4"
                        Background="Transparent"
                        Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding ToggleExpandCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 图标 -->
                        <TextBlock Grid.Column="0"
                                   FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"
                                   Text="🛠️"/>

                        <!-- 标题 -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayTitle}"
                                   FontSize="11"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,8,0" />

                        <!-- 摘要标签 -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding SummaryTag}"
                                   FontSize="10"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0" />

                        <!-- 撑满 -->
                        <Rectangle Grid.Column="3" Fill="Transparent"/>

                        <!-- 新增/删除行数 -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal">
                            <!-- 新增行数（绿色） -->
                            <TextBlock FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#66BB6A"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"
                                       Visibility="{Binding HasLinesAdded, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Run Text="+"/>
                                <Run Text="{Binding LinesAdded}"/>
                                <Run Text="行"/>
                            </TextBlock>
                            <!-- 删除行数（红色） -->
                            <TextBlock FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="#EF5350"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"
                                       Visibility="{Binding HasLinesRemoved, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Run Text="-"/>
                                <Run Text="{Binding LinesRemoved}"/>
                                <Run Text="行"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- 执行中状态 -->
                        <TextBlock Grid.Column="5"
                                   Text="执行中…"
                                   FontSize="10"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- 成功标记（绿色勾） -->
                        <TextBlock Grid.Column="5"
                                   Text="✅"
                                   FontSize="11"
                                   Foreground="#00AA00"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"
                                   Visibility="{Binding IsSuccess, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- 警告标记（黄色叹号） -->
                        <TextBlock Grid.Column="5"
                                   Text="⚠️"
                                   FontSize="11"
                                   Foreground="#FFA726"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"
                                   Visibility="{Binding IsWarning, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- 错误标记（红色叉） -->
                        <TextBlock Grid.Column="5"
                                   Text="❌"
                                   FontSize="11"
                                   Foreground="#FF0050"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"
                                   Visibility="{Binding IsError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- 中止按钮（仅执行中的工具显示） -->
                        <TextBlock Grid.Column="6"
                                   Text="中止任务 ✕"
                                   FontSize="11"
                                   Foreground="#EF5350"
                                   VerticalAlignment="Center"
                                   Cursor="Hand"
                                   Margin="0,0,2,0"
                                   Visibility="{Binding HasCancelButton, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding CancelToolCommand}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- 执行结果（折叠/展开） -->
                <Border Grid.Row="1"
                        Padding="12,0,0,4"
                        Background="Transparent"
                        BorderThickness="3,0,0,0"
                        BorderBrush="{DynamicResource BrushTextMuted}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding Result}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               FontFamily="Consolas, Microsoft YaHei"
                               Margin="0,4,0,0" />
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- [A8] 追加消息块 — 显示在 AI 消息的 TimelineItems 中 -->
    <DataTemplate DataType="{x:Type vm:FollowUpBlock}">
        <Border Padding="8,5"
                Margin="0,4,0,4"
                Background="{DynamicResource BrushBubbleUser}"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{DynamicResource BrushBorder}">
            <TextBlock TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondary}">
                <Run FontWeight="SemiBold" Text="💬 追加" />
                <Run Text="：" />
                <Run Text="{Binding Content}" />
            </TextBlock>
        </Border>
    </DataTemplate>

    <!-- RoundBlock — 轮次块（思考+工具+文本） -->
    <DataTemplate DataType="{x:Type vm:RoundBlock}">
        <Border Padding="0"
                Margin="0,0,0,14">
            <StackPanel>
                <!-- 思考块 -->
                <ContentControl Content="{Binding Reasoning}"
                                Visibility="{Binding HasReasoning, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,10" />

                <!-- 内容区：流式 TextBlock ↔ MarkdownViewer 二选一 -->
                <ContentControl Content="{Binding}"
                                Visibility="{Binding ShouldShowContent, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,8">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate" Value="{StaticResource RoundBlockStreamingContent}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStreaming}" Value="False">
                                    <Setter Property="ContentTemplate" Value="{StaticResource RoundBlockRenderedContent}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

                <!-- 分隔线（既有文本又有工具时） -->
                <Border Height="1"
                        Background="{DynamicResource BrushDivider}"
                        Margin="0,6"
                        Visibility="{Binding HasBothContentAndTools, Converter={StaticResource BoolToVisibilityConverter}}" />

                <!-- 工具调用列表 -->
                <ItemsControl ItemsSource="{Binding ToolCalls}"
                              Visibility="{Binding HasToolCalls, Converter={StaticResource BoolToVisibilityConverter}}"
                              Margin="0,4,0,0" />
            </StackPanel>
        </Border>
    </DataTemplate>

</ResourceDictionary>
