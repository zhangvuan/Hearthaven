<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════ 极简蓝白主题：配色调色板 ═══════════════ -->
    <!-- 背景 -->
    <SolidColorBrush x:Key="BrushBg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BrushSidebar" Color="#F8F9FA" />
    <SolidColorBrush x:Key="BrushChatBg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BrushBorder" Color="#E9ECEF" />
    <SolidColorBrush x:Key="BrushDivider" Color="#F0F0F0" />

    <!-- 文字 -->
    <SolidColorBrush x:Key="BrushText" Color="#212529" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#868E96" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="#ADB5BD" />

    <!-- 气泡 -->
    <SolidColorBrush x:Key="BrushBubbleUser" Color="#E7F5FF" />
    <SolidColorBrush x:Key="BrushBubbleAssistant" Color="#F8F9FA" />

    <!-- 交互 -->
    <SolidColorBrush x:Key="BrushAccent" Color="#339AF0" />
    <SolidColorBrush x:Key="BrushHover" Color="#F1F3F5" />
    <SolidColorBrush x:Key="BrushDanger" Color="#E03131" />

    <!-- 输入区 -->
    <SolidColorBrush x:Key="BrushInputBg" Color="#F8F9FA" />
    <SolidColorBrush x:Key="BrushInputBorder" Color="#DEE2E6" />

    <!-- 表格斑马纹交替色 -->
    <SolidColorBrush x:Key="BrushRowAlt" Color="#F5F7F9" />

    <!-- Token 使用率指示色 -->
    <SolidColorBrush x:Key="BrushTokenGreen" Color="#4CAF50" />
    <SolidColorBrush x:Key="BrushTokenOrange" Color="#FF9800" />
    <SolidColorBrush x:Key="BrushTokenRed" Color="#F44336" />

</ResourceDictionary>
