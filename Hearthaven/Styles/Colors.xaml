<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════ 颜色调色板（清爽极简风） ═══════════════ -->
    <!-- 主色 -->
    <Color x:Key="ColorBg">#FFFFFF</Color>
    <Color x:Key="ColorSidebar">#F8F9FA</Color>
    <Color x:Key="ColorChatBg">#FFFFFF</Color>
    <Color x:Key="ColorBorder">#E9ECEF</Color>
    <Color x:Key="ColorDivider">#F0F0F0</Color>

    <!-- 文字 -->
    <Color x:Key="ColorText">#212529</Color>
    <Color x:Key="ColorTextSecondary">#868E96</Color>
    <Color x:Key="ColorTextMuted">#ADB5BD</Color>

    <!-- 气泡 -->
    <Color x:Key="ColorBubbleUser">#E7F5FF</Color>
    <Color x:Key="ColorBubbleAssistant">#F8F9FA</Color>

    <!-- 交互 -->
    <Color x:Key="ColorAccent">#339AF0</Color>
    <Color x:Key="ColorHover">#F1F3F5</Color>
    <Color x:Key="ColorDanger">#E03131</Color>

    <!-- 输入区 -->
    <Color x:Key="ColorInputBg">#F8F9FA</Color>
    <Color x:Key="ColorInputBorder">#DEE2E6</Color>

    <!-- 刷子 -->
    <SolidColorBrush x:Key="BrushBg" Color="{StaticResource ColorBg}" />
    <SolidColorBrush x:Key="BrushSidebar" Color="{StaticResource ColorSidebar}" />
    <SolidColorBrush x:Key="BrushChatBg" Color="{StaticResource ColorChatBg}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushDivider" Color="{StaticResource ColorDivider}" />
    <SolidColorBrush x:Key="BrushText" Color="{StaticResource ColorText}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="BrushBubbleUser" Color="{StaticResource ColorBubbleUser}" />
    <SolidColorBrush x:Key="BrushBubbleAssistant" Color="{StaticResource ColorBubbleAssistant}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushHover" Color="{StaticResource ColorHover}" />
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="BrushInputBg" Color="{StaticResource ColorInputBg}" />
    <SolidColorBrush x:Key="BrushInputBorder" Color="{StaticResource ColorInputBorder}" />

    <!-- Token 使用率指示色 -->
    <SolidColorBrush x:Key="BrushTokenGreen" Color="#4CAF50" />
    <SolidColorBrush x:Key="BrushTokenOrange" Color="#FF9800" />
    <SolidColorBrush x:Key="BrushTokenRed" Color="#F44336" />

</ResourceDictionary>
