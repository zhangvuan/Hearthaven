<UserControl x:Class="Hearthaven.Views.SettingsTabs.SettingsAgentTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <!-- 资料卡 -->
            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <!-- 头像 -->
                    <Border Grid.Column="0"
                            Width="90" Height="90"
                            CornerRadius="20"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BrushBorder}"
                            Background="{DynamicResource BrushBg}"
                            Margin="0,0,20,0">
                        <Image Source="{Binding AvatarPath}"
                               Width="90" Height="90"
                               Stretch="UniformToFill">
                            <Image.Clip>
                                <RectangleGeometry RadiusX="20" RadiusY="20"
                                                   Rect="0,0,90,90" />
                            </Image.Clip>
                        </Image>
                    </Border>
                    <!-- 名称/身份/称呼 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Agent 名称" Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,3" />
                        <TextBox Text="{Binding AgentName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldInput}" />

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="身份（如：助手）"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,3" />
                                <TextBox Text="{Binding Identity, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldInput}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="称呼（如：主人）"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,3" />
                                <TextBox Text="{Binding CallAs, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldInput}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 角色文件提示 -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="📝 角色自定义文件"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushText}"
                               Margin="0,0,0,10" />
                    <TextBlock TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               LineHeight="18">
                        <Run Text="角色性格保存在用户目录下的" />
                        <Run FontWeight="SemiBold" Text="SOUL.md" />
                        <Run Text="文件，额外行为指令保存在" />
                        <Run FontWeight="SemiBold" Text="AGENT.md" />
                        <Run Text="文件，可自由编辑，保存后下次对话自动生效。" />
                    </TextBlock>
                    <Button Content="📂 打开用户目录"
                            Style="{StaticResource TextButton}"
                            Margin="0,8,0,0"
                            Command="{Binding OpenProfileDirectoryCommand}" />
                </StackPanel>
            </Border>

            <!-- 推理参数 -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="🧠 推理参数"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushText}"
                               Margin="0,0,0,12" />

                    <!-- Temperature -->
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Temperature"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrushTextSecondary}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Temperature, StringFormat={}{0:F1}}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushAccent}" />
                        </Grid>
                        <Slider Minimum="0" Maximum="2"
                                SmallChange="0.1" LargeChange="0.5"
                                Value="{Binding Temperature}"
                                TickFrequency="0.5" TickPlacement="BottomRight"
                                Style="{StaticResource ModernSlider}"
                                Margin="0,4,0,4" />
                    </StackPanel>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="响应预留 Token"
                                       Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding MaxResponseTokens, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FieldInputNarrow}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="请求超时（秒）"
                                       Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FieldInputNarrow}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
