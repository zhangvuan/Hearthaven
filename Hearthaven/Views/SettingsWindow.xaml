<Window x:Class="Hearthaven.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tabs="clr-namespace:Hearthaven.Views.SettingsTabs"
        mc:Ignorable="d"
        Title="设置" Width="640" Height="520"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontFamily}"
        FontSize="13"
        Background="{DynamicResource BrushChatBg}"
        ShowInTaskbar="False"
        MinWidth="500" MinHeight="400"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderThickness="0">
    <Window.Resources>
        <ResourceDictionary />
    </Window.Resources>

    <!-- ===== 整体窗口（无边框圆角弹窗） ===== -->
    <Border CornerRadius="12"
            Margin="1"
            Background="{DynamicResource BrushBg}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1">
        <DockPanel>
            <!-- ===== 自定义标题栏 ===== -->
            <Border DockPanel.Dock="Top"
                    Background="Transparent"
                    Padding="20,14,16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="⚙️ 设置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushText}"
                               VerticalAlignment="Center" />
                    <!-- 关闭按钮 -->
                    <Button Grid.Column="2"
                            Width="28" Height="28"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Click="OnCancel"
                            ToolTip="关闭">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BrushHover}" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource BrushBorder}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="✕"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <!-- ===== 分割线 ===== -->
            <Border DockPanel.Dock="Top"
                    Height="1"
                    Background="{DynamicResource BrushDivider}" />

            <!-- ===== 底部操作栏（左提示 + 右按钮） ===== -->
            <Border DockPanel.Dock="Bottom"
                    BorderBrush="{DynamicResource BrushDivider}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12"
                    Background="{DynamicResource BrushBg}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- 左侧提示 -->
                    <TextBlock Grid.Column="0"
                               Text="设置保存后部分配置将在下次对话时生效"
                               FontSize="11"
                               Foreground="{DynamicResource BrushTextMuted}"
                               VerticalAlignment="Center" />
                    <!-- 取消按钮 -->
                    <Button Grid.Column="1"
                            Content="取消"
                            Style="{StaticResource TextButton}"
                            Padding="16,8"
                            Click="OnCancel" />
                    <!-- 保存按钮 -->
                    <Button Grid.Column="2"
                            Content="💾 保存设置"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}" />
                </Grid>
            </Border>

            <!-- ===== Tab 内容 ===== -->
            <TabControl Style="{StaticResource ModernTabControl}"
                        SelectedIndex="0"
                        BorderThickness="0"
                        Background="{x:Null}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}" />
                </TabControl.Resources>

                <!-- Tab 1: 📡 服务商 -->
                <TabItem Header="📡 服务商">
                    <tabs:SettingsProviderTab />
                </TabItem>

                <!-- Tab 2: 🧑 Agent -->
                <TabItem Header="🧑 Agent">
                    <tabs:SettingsAgentTab />
                </TabItem>

                <!-- Tab 3: 🛠️ 工具 -->
                <TabItem Header="🛠️ 工具">
                    <tabs:SettingsToolsTab />
                </TabItem>

                <!-- Tab 4: 🎨 界面 -->
                <TabItem Header="🎨 界面">
                    <tabs:SettingsUiTab />
                </TabItem>

                <!-- Tab 5: ℹ️ 关于 -->
                <TabItem Header="ℹ️ 关于">
                    <tabs:SettingsAboutTab />
                </TabItem>
            </TabControl>

        </DockPanel>
    </Border>
</Window>
